local Players=game:GetService("Players")
local Workspace=game:GetService("Workspace")
local RunService=game:GetService("RunService")
local LocalPlayer=Players.LocalPlayer
local autoStealEnabled=true
local promptCache={}
local RAD=20
local RATE=0.06
local stealConnection=nil
local Char,HRP
local function SetupCharacter(c)
Char=c
HRP=c:WaitForChild("HumanoidRootPart",10)
end
if LocalPlayer.Character then
SetupCharacter(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(function(c)
task.wait(0.1)
SetupCharacter(c)
end)
local function GetPromptPosition(prompt)
local pos
pcall(function()
local par=prompt.Parent
if par:IsA("BasePart") then
pos=par.Position
elseif par:IsA("Attachment") then
pos=par.WorldPosition
elseif par:IsA("Model") then
local pp=par.PrimaryPart or par:FindFirstChildWhichIsA("BasePart")
if pp then pos=pp.Position end
else
local bp=par:FindFirstChildWhichIsA("BasePart",true)
if bp then pos=bp.Position end
end
end)
return pos
end
local yUp=0.1
local yDown=12
local function FindStealPrompt(targetPart)
if not targetPart then return nil end
local plots=Workspace:FindFirstChild("Plots")
if not plots then return nil end
local targetPos=targetPart.Position
local radius=6
for _,plot in pairs(plots:GetChildren()) do
for _,dsc in pairs(plot:GetDescendants()) do
if dsc:IsA("ProximityPrompt") and dsc.Enabled and dsc.ActionText=="Steal" then
local promptPos=GetPromptPosition(dsc)
if promptPos then
local horizontalDist=math.sqrt((targetPos.X - promptPos.X)^2 + (targetPos.Z - promptPos.Z)^2)
local verticalDistUp=promptPos.Y - targetPos.Y
local verticalDistDown=targetPos.Y - promptPos.Y
if horizontalDist < radius and verticalDistUp <=yUp and verticalDistDown <=yDown then
return dsc
end
end
end
end
end
return nil
end
local function BuildPromptCache(prompt)
if promptCache[prompt] then return end
local d={holdFuncs={},triggerFuncs={},ready=true}
if getconnections then
local ok1,c1=pcall(getconnections,prompt.PromptButtonHoldBegan)
if ok1 and type(c1)=="table" then
for _,cn in ipairs(c1) do
if type(cn.Function)=="function" then
table.insert(d.holdFuncs,cn.Function)
end
end
end
local ok2,c2=pcall(getconnections,prompt.Triggered)
if ok2 and type(c2)=="table" then
for _,cn in ipairs(c2) do
if type(cn.Function)=="function" then
table.insert(d.triggerFuncs,cn.Function)
end
end
end
end
if #d.holdFuncs > 0 or #d.triggerFuncs > 0 then
promptCache[prompt]=d
end
end
local function ExecutePrompt(prompt)
local d=promptCache[prompt]
if not d or not d.ready then return false end
d.ready=false
task.spawn(function()
for _,fn in ipairs(d.holdFuncs) do
task.spawn(fn)
end
task.wait(0.1)
for _,fn in ipairs(d.triggerFuncs) do
task.spawn(fn)
end
task.wait(0.01)
d.ready=true
end)
return true
end
local function FirePrompt(prompt)
local fired=false
if fireproximityprompt then
pcall(function()
prompt.HoldDuration=0
fireproximityprompt(prompt,0,0)
fired=true
end)
end
if fired then return end
if getconnections then
local ok,cs=pcall(getconnections,prompt.Triggered)
if ok and type(cs)=="table" then
for _,c in ipairs(cs) do
if c.Function then
task.spawn(c.Function)
end
end
return
end
end
pcall(function()
prompt:InputHoldBegin()
task.delay(0.05,function()
pcall(function() prompt:InputHoldEnd() end)
end)
end)
end
local function AutoStealAll()
if not HRP then return end
local debris=Workspace:FindFirstChild("Debris")
if not debris then return end
for _,t in ipairs(debris:GetChildren()) do
if t.Name=="FastOverheadTemplate" then
local sg=t:FindFirstChildOfClass("SurfaceGui")
if sg and sg.Adornee and sg.Adornee.Parent then
local part=sg.Adornee
if part and part:IsA("BasePart") then
local stealPrompt=FindStealPrompt(part)
if stealPrompt then
local promptPos=GetPromptPosition(stealPrompt)
if promptPos then
local dist=(HRP.Position - promptPos).Magnitude
if dist <=RAD then
BuildPromptCache(stealPrompt)
if not ExecutePrompt(stealPrompt) then
FirePrompt(stealPrompt)
end
end
end
end
end
end
end
end
end
local timer=0
stealConnection=RunService.Heartbeat:Connect(function(dt)
if autoStealEnabled then
timer=timer + dt
if timer >=RATE then
timer=0
AutoStealAll()
end
end
end)
_G.ToggleAutoSteal=function(enabled)
autoStealEnabled=enabled
end
_G.ToggleAutoSteal(true)
