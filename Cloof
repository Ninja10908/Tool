local Players=game:GetService("Players")
local RunService=game:GetService("RunService")
local localPlayer=Players.LocalPlayer
local activeData={}
local myAttach=Instance.new("Attachment")
local isESPEnabled=false
local espConnections={}
local function createTracker(target)
if not isESPEnabled then return end
if activeData[target] then return end
if target.Name=="mziry827" then return end
local char=target.Character
if not char then return end
local function setupESP()
if not char or not char.Parent then return end
local root=char:FindFirstChild("HumanoidRootPart")
local head=char:FindFirstChild("Head")
if not root then return end
local tAttach=root:FindFirstChild("StealerESPAttach")
if not tAttach then
tAttach=Instance.new("Attachment",root)
tAttach.Name="StealerESPAttach"
end
local beam=Instance.new("Beam")
beam.Attachment0=myAttach
beam.Attachment1=tAttach
beam.Width0,beam.Width1=0.1,0.1
beam.Color=ColorSequence.new(Color3.new(1,0,0))
beam.FaceCamera=true
beam.Parent=root
local bgui=Instance.new("BillboardGui")
bgui.Name="ThiefTag"
bgui.Size=UDim2.new(0,200,0,50)
bgui.AlwaysOnTop=true
bgui.ExtentsOffset=Vector3.new(0,3,0)
bgui.Adornee=head or root
bgui.Parent=char
local tl=Instance.new("TextLabel")
tl.Size=UDim2.new(1,0,1,0)
tl.BackgroundTransparency=1
tl.TextColor3=Color3.new(1,1,1)
tl.TextStrokeTransparency=0.5
tl.Font=Enum.Font.GothamBold
tl.TextSize=14
tl.Text=target.DisplayName .. "\n(@" .. target.Name .. ")"
tl.Parent=bgui
activeData[target]={
B=beam,G=bgui,Attach=tAttach,Character=char
}
end
setupESP()
if not char then
local conn
conn=target.CharacterAdded:Connect(function(newChar)
if conn then conn:Disconnect() end
task.wait(0.5)
if isESPEnabled then
setupESP()
end
end)
end
end
local function clean(target)
if activeData[target] then
if activeData[target].B then activeData[target].B:Destroy() end
if activeData[target].G then activeData[target].G:Destroy() end
activeData[target]=nil
end
end
local function updateMyAttachment()
if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
if not myAttach or not myAttach.Parent then
myAttach=Instance.new("Attachment")
myAttach.Name="MyESPAttachment"
end
myAttach.Parent=localPlayer.Character.HumanoidRootPart
end
end
local function checkPlayers()
updateMyAttachment()
for _,p in ipairs(Players:GetPlayers()) do
if p==localPlayer then continue end
if p.Name=="mziry827" then
clean(p)
continue
end
if p:GetAttribute("Stealing")==true then
if not activeData[p] then
createTracker(p)
else
if activeData[p].B and activeData[p].B.Attachment0 ~=myAttach then
activeData[p].B.Attachment0=myAttach
end
end
else
clean(p)
end
end
end
_G.enableStealerESP=function()
isESPEnabled=true
myAttach=Instance.new("Attachment")
updateMyAttachment()
espConnections.render=RunService.RenderStepped:Connect(checkPlayers)
espConnections.myRespawn=localPlayer.CharacterAdded:Connect(function(char)
task.wait(1)
updateMyAttachment()
end)
espConnections.playerAdded=Players.PlayerAdded:Connect(function(player)
if player.Name=="mziry827" then return end
player:GetAttributeChangedSignal("Stealing"):Connect(function()
if player:GetAttribute("Stealing")==true then
createTracker(player)
else
clean(player)
end
end)
end)
for _,player in ipairs(Players:GetPlayers()) do
if player ~=localPlayer then
if player.Name=="mziry827" then continue end
espConnections[player]=player:GetAttributeChangedSignal("Stealing"):Connect(function()
if player:GetAttribute("Stealing")==true then
createTracker(player)
else
clean(player)
end
end)
if player:GetAttribute("Stealing")==true then
createTracker(player)
end
end
end
end
_G.disableStealerESP=function()
isESPEnabled=false
for target,_ in pairs(activeData) do
clean(target)
end
activeData={}
if myAttach then
myAttach:Destroy()
end
for name,conn in pairs(espConnections) do
if conn then
conn:Disconnect()
end
end
espConnections={}
end
_G.enableStealerESP()
